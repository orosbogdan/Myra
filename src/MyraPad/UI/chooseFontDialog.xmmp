<Project>
  <Project.ExportOptions Namespace="MyraPad.UI" Class="ChooseFontDialog" OutputPath="D:\Projects\Myra\src\MyraPad\UI" />
  <Dialog Title="Choose Font" Left="363" Top="150" Width="600" Height="600">
    <VerticalStackPanel Spacing="8">
      <HorizontalStackPanel Spacing="8">
        <Label Text="Filter:" />
        <TextBox Id="_textFilter" StackPanel.ProportionType="Fill" />
      </HorizontalStackPanel>
      <ScrollViewer StackPanel.ProportionType="Fill">
        <VerticalStackPanel Spacing="4">
          <Grid>
            <Grid.DefaultRowProportion Type="Auto" />
            <Grid.ColumnsProportions>
              <Proportion Type="Pixels" Value="200" />
              <Proportion Type="Pixels" Value="50" />
              <Proportion Type="Fill" />
            </Grid.ColumnsProportions>
            <Label Text="Source" />
            <Label Text="Size" Grid.Column="1" />
            <Label Text="Name" Grid.Column="2" />
          </Grid>
          <Grid RowSpacing="4" GridSelectionMode="Row" Id="_gridData">
            <Grid.DefaultRowProportion Type="Auto" />
            <Grid.ColumnsProportions>
              <Proportion Type="Pixels" Value="200" />
              <Proportion Type="Pixels" Value="50" />
              <Proportion Type="Fill" />
            </Grid.ColumnsProportions>
            <Label Text="MonoDroid.ttf" VerticalAlignment="Center" />
            <Label Text="32" VerticalAlignment="Center" Grid.Column="1" />
            <Label Text="default-font" VerticalAlignment="Center" Grid.Column="2" />
          </Grid>
        </VerticalStackPanel>
      </ScrollViewer>
    </VerticalStackPanel>
  </Dialog>
</Project>